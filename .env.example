# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-JTJM0BPTEQ

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Dev/test only — sends to your Resend account email. For production, verify your domain first:
# https://resend.com/domains (add DNS records for coletivoaurora.pt)
RESEND_FROM_EMAIL=Coletivo Aurora <onboarding@resend.dev>
# Production sender (after domain verification):
# RESEND_FROM_EMAIL=Coletivo Aurora <noreply@coletivoaurora.pt>
# Inbox for form submissions (default: somosaurora@gmail.com)
AURORA_INBOX_EMAIL=somosaurora@gmail.com

# Google AI Studio API key — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional override (default: gemini-3.1-flash-lite — GA, June 2026)
# Alternatives: gemini-3.5-flash (mais capaz), gemini-3.1-pro-preview (requer billing)
# GEMINI_ASSISTANT_MODEL=gemini-3.1-flash-lite

# Witflow CMS — headless blog for /diario
# CMS Admin → Users → Coletivo Aurora → Client ID, Webhook URL, Webhook Secret
CMS_API_BASE_URL=
CMS_SITE_ID=
CMS_API_KEY=
CMS_WEBHOOK_SECRET=
CMS_LOCALE=pt
NEXT_PUBLIC_SITE_URL=https://coletivoaurora.pt
